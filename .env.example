# Neon PostgreSQL connection strings
# Get both from: https://console.neon.tech/<project> → Connect → Connection details
#
# DATABASE_URL: pooled connection (has "-pooler" in hostname). Used at runtime
# by @prisma/adapter-neon over WebSocket. Optimal for serverless.
#
# DIRECT_URL: direct (unpooled) connection. Used by Prisma CLI for migrations,
# db push, and introspect. Required because the schema engine needs direct TCP.
#
# connect_timeout=15 accommodates Neon's cold start when compute scales to zero.

DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require&connect_timeout=15"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require&connect_timeout=15"

# NextAuth v5
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET=

# GitHub OAuth app
# Create at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
